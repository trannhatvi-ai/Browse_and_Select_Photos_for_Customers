# Database (Dùng Neon.tech hoặc Supabase - Miễn phí)
DATABASE_URL="postgresql://postgres:[password]@db.[id].supabase.co:5432/postgres"

# Cloudinary (Lưu ảnh - Miễn phí vĩnh viễn)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@yourstudio.com"

# Redis (for Bull queue - optional, uses in-memory if not set)
# REDIS_URL="redis://localhost:6379"

# Application
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BACKEND_URL="http://localhost:8000"
