# Database (Dùng Neon.tech hoặc Supabase - Miễn phí)
DATABASE_URL="postgresql://postgres:[password]@db.[id].supabase.co:5432/postgres"

# Cloudinary (Lưu ảnh - Miễn phí vĩnh viễn)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="Studio Pro <studiopro1008@gmail.com>"
STUDIO_CONTACT_EMAIL="studiopro1008@gmail.com"
STUDIO_PHONE="090 xxxx xxxx"

# Auth (NextAuth + Google OAuth)
NEXTAUTH_SECRET="change-me"
GOOGLE_CLIENT_ID="your_google_oauth_client_id"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"

# SMS OTP webhook (optional, POST JSON: { to, message, purpose })
SMS_WEBHOOK_URL=""
SMS_WEBHOOK_SECRET=""

# Application
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BACKEND_URL="http://localhost:8000"
